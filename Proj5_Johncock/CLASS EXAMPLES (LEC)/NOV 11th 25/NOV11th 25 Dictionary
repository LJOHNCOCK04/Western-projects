def functions_for_dict():
    dict1={
        'a':'Alice','b':'bob'
        }
    #CLEAR---- clear the dictionar but wont delete the whole thing
    dict1.clear()

    #GET---- gets value from key and retruns none(unless edited) if nothing is found
    value=dict1.get('a')
    print (value)
    value=dict1.get('c', 'the key is not found!')
    print (value)

    #ITEMS----
    pairs =dict1.items()
    print(pairs)
# OUTPUT: dict_items ([(whatever in dict)])

# to fix put:
    for key,value in pairs:
        print (key,value)

    #KEYS---- # find the keys and puts them in a list 
    keys = dict1.keys()
    for k in keys :
        print(k)

    #POP---- #retrun and removes a key from dict
    print(dict1.pop('b'))
    print(dict1)

    #POPITEM---- returns a tuple
    dict1={
        'a':'Alice','b':'bob', 'c': 'Zoe'
        }
    print(dict1.popitem('b'))
    print(dict1)

    #VALUES----
    values = (dict1.values())

    for v in values:
        print(v)


