def making_a_dict_combining():
    dict1= {
        'a':'Alice','b':'bob','c':'Zoe'
    }

    dict2 = {
        'd':"david", 's':'Sophie', 'c':'Adam'
    }
# the dict on the right of the bar will override the one on the left.
# combinding will always replace any similar keys.
    dict3 = dict1 | dict2

    print(dict3)

def making_a_dict_updating():
    dict1= {
        'a':'Alice','b':'bob','c':'Zoe'
    }

    dict2 = {
        'd':"david", 's':'Sophie', 'c':'Adam'
    }
    dict1|=dict2
    print(dict1)




